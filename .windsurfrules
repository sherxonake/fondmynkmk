## REACT КОМПОНЕНТЫ

```typescript
// ✅ Идеальная структура компонента

// 1. Imports (сначала внешние, потом внутренние)
import { useState, useCallback } from 'react'
import { motion } from 'framer-motion'
import type { NewsArticle } from '@/types'
import { formatDate } from '@/lib/utils'
import { Card } from '@/components/ui/card'

// 2. Types/Interfaces
interface NewsCardProps {
  article: NewsArticle
  onSelect?: (id: string) => void
  className?: string
}

// 3. Компонент
export function NewsCard({ article, onSelect, className }: NewsCardProps) {
  // 3a. Хуки (только если 'use client')
  const [isExpanded, setIsExpanded] = useState(false)

  // 3b. Derived state (без useEffect если можно)
  const formattedDate = formatDate(article.publishedAt)

  // 3c. Handlers (useCallback для стабильных ссылок)
  const handleClick = useCallback(() => {
    onSelect?.(article.id)
  }, [article.id, onSelect])

  // 3d. JSX — максимально читаемый
  return (
    <Card className={className} onClick={handleClick}>
      <h2>{article.title}</h2>
      <time dateTime={article.publishedAt}>{formattedDate}</time>
    </Card>
  )
}
```

### Правила компонентов:
- Один файл = один основной компонент (мелкие helper-компоненты рядом — ок)
- Props через interface, не inline type
- Опциональные props всегда с `?` и дефолтным значением где нужно
- `children: React.ReactNode` для компонентов-обёрток
- Избегай `useEffect` для derived state — считай прямо в рендере
- `key` в списках — всегда уникальный стабильный ID, не index
- Мемоизация (`useMemo`, `useCallback`, `React.memo`) — только при реальной проблеме производительности, не превентивно
- Всегда используй абсолютные импорты через алиас `@/` (например, `@/components/ui/...`). Никогда не используй относительные пути вроде `../../`.

